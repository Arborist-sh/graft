{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Graft",
  "scopeName": "source.graft",
  "patterns": [
    { "include": "#comment" },
    { "include": "#embedded-script" },
    { "include": "#toolchain-key" },
    { "include": "#key" },
    { "include": "source.yaml" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.graft"
    },
    "embedded-script": {
      "comment": "run:/script: block scalar — highlight its body as shell",
      "begin": "^(\\s*)(run|script)\\s*(:)\\s*([|>][-+]?)\\s*$",
      "beginCaptures": {
        "2": { "name": "keyword.control.graft" },
        "3": { "name": "punctuation.separator.key-value.graft" },
        "4": { "name": "keyword.operator.block-scalar.graft" }
      },
      "while": "^(?:\\1\\s|\\s*$)",
      "contentName": "meta.embedded.block.shellscript",
      "patterns": [{ "include": "source.shell" }]
    },
    "toolchain-key": {
      "comment": "graft's declarative fields",
      "match": "^(\\s*)(name|from|xcode|node|ruby|python|java|go|rust|package-manager|brew|cocoapods|fastlane|gems|npm|xcode-first-launch|simulator-runtimes|warm-simulators|env|git|known-hosts|write|timezone|hostname|disable-spotlight|disable-sleep|description|labels|pod-repo-warm|prefetch|repos|verify|cleanup|cpu|memory|disk|display|script|mounts|os|network|run)(?=\\s*:)",
      "captures": {
        "2": { "name": "keyword.control.graft" }
      }
    },
    "key": {
      "comment": "any other YAML key",
      "match": "^(\\s*)([\\w-]+)(?=\\s*:)",
      "captures": {
        "2": { "name": "entity.name.tag.yaml" }
      }
    }
  }
}
